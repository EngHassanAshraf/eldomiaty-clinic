# ── Backend Environment Variables ───────────────────────────────────────────
# In Vercel dashboard → Settings → Environment Variables, add these:

# Supabase PostgreSQL connection string (use the "Transaction" pooler URL for serverless)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct URL for Prisma migrations (use the "Session" pooler or direct connection)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://eldomiaty-clinic.vercel.app/payment/success
STRIPE_CANCEL_URL=https://eldomiaty-clinic.vercel.app/payment/cancel
STRIPE_PRICE_ID=price_...

# Supabase Storage
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=clinic-files

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=https://eldomiaty-clinic.vercel.app

# Port (Vercel ignores this, but needed for local dev)
PORT=3001
